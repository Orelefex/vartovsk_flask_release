# Пример файла .env для METAR/TAF Decoder
# Скопируйте этот файл в .env и настройте под свои нужды

# ===== Flask настройки =====
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# ===== Таймауты для внешних API (секунды) =====
REQUESTS_TIMEOUT=15
OGIMET_TIMEOUT=15
AVIA_METEO_TIMEOUT=5
UWYO_TIMEOUT=30

# ===== URLs внешних источников =====
AVIA_METEO_METAR_URL=https://www.avia-meteo.ru/data/metar.txt
AVIA_METEO_TAF_URL=https://www.avia-meteo.ru/data/taf.txt
OGIMET_BASE_URL=https://ogimet.com/display_metars2.php
UWYO_SOUNDING_URL=https://weather.uwyo.edu/cgi-bin/sounding

# ===== Кэширование =====
CACHE_ENABLED=true
CACHE_TTL_METAR=300
CACHE_TTL_TAF=1800
CACHE_TTL_SOUNDING=3600
CACHE_MAX_SIZE=1000

# ===== Логирование =====
LOG_LEVEL=INFO
LOG_FILE=logs/metar_app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ===== Файлы данных =====
ICAO_CSV_FILE=ICAO.csv
AERO_STATIONS_FILE=aero_index.json
